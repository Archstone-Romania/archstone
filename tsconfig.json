{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@archstone/schema": ["packages/schema/src/index.ts"],
      "@archstone/compiler": ["packages/compiler/src/index.ts"],
      "@archstone/emitter-support": ["packages/emitter-support/src/index.ts"],
      "@archstone/agent": ["packages/agent/src/index.ts"],
      "@archstone/runtime": ["packages/runtime/src/index.ts"],
      "@archstone/runtime/http": ["packages/runtime/src/http.ts"],
      "@archstone/provider-rest": ["providers/rest/src/index.ts"]
    }
  },
  "include": [
    "packages/**/src/**/*.ts",
    "packages/**/test/**/*.ts",
    "providers/**/src/**/*.ts"
  ]
}
