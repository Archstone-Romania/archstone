  "dependencies": {
    "@archstone/runtime": "workspace:*",
    "@archstone/compiler": "workspace:*",
    "@archstone/provider-rest": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5",
    "wrangler": "^4.0.0"
  }
}
