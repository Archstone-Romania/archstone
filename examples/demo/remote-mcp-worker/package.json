{
  "name": "archstone-demo-remote-mcp-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Growth/demo-only infra for the archstone-website 'try it live' section. NOT a Phase-2 product decision — see README.md.",
  "scripts": {
    "build:ir": "tsx scripts/build-ir.ts",
    "dev": "pnpm build:ir && wrangler dev",
    "deploy": "pnpm build:ir && wrangler deploy",
    "typecheck": "pnpm build:ir && tsc -p tsconfig.json",
    "test": "pnpm build:ir && vitest run"
