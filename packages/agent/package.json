{
  "name": "@archstone/agent",
  "version": "0.3.2",
  "private": false,
  "type": "module",
  "description": "Embedded agent SDK (RFC-0008/ADD-0008): tool definitions (Anthropic/OpenAI/Gemini/JSON-Schema) + fail-closed execute() over compiled IR. Root entry — zero MCP SDK reachability; /mcp subpath — mountable Streamable-HTTP handler.",
  "license": "Apache-2.0",
  "homepage": "https://archstone.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Archstone-Romania/archstone.git",
    "directory": "packages/agent"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "default": "./dist/mcp.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@archstone/compiler": "workspace:*",
    "@archstone/emitter-support": "workspace:*",
    "@archstone/provider-rest": "workspace:*",
    "@archstone/runtime": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
