{
  "name": "@archstone/schema",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Schema Loader (#2): load + validate deployable CDL manifests from disk.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "schemas"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
