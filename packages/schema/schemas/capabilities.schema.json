{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archstone.dev/schema/v1/capabilities.schema.json",
  "title": "capabilities.yaml",
  "description": "The iconic Archstone manifest — a company's contract with the AI world. Like openapi.yaml or docker-compose.yaml.",
  "type": "object",
  "additionalProperties": false,
  "required": ["company", "capabilities", "providers"],
  "properties": {
    "company": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Company / tenant identifier (e.g. booking)"
        },
        "name": {
          "type": "string",
          "description": "Human-readable company name"
        },
        "description": {
          "type": "string",
          "description": "What this company offers to AI agents"
        }
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$",
        "description": "Capability ID — must match a *.capability.yaml in this directory"
      },
      "uniqueItems": true
    },
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$",
        "description": "Provider system identifiers (e.g. booking-api, crm, payment)"
      },
      "uniqueItems": true
    }
  }
}
