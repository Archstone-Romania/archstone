  "license": "Apache-2.0",
  "homepage": "https://archstone.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Archstone-Romania/archstone.git",
    "directory": "packages/emitter-support"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
